          "fontWeight": "var(--wp--custom--font-weight--semi-bold)",
          "lineHeight": "var(--wp--custom--line-height--xx-small)",
          "letterSpacing": "-2px"
        },
        "color": {
          "text": "var(--wp--preset--color--heading)"
        },
        "spacing": {
          "margin": {
            "bottom": "var(--wp--preset--spacing--small)"
          }
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xxx-large)",
