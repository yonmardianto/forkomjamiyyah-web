          "background": "var(--wp--preset--color--accent)",
          "text": "var(--wp--preset--color--accent-text)"
        },
        "border": {
          "radius": "0px",
          "color": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "#ffffff",
            "background": "var(--wp--preset--color--hover)"
          }
        },
        ":focus": {
          "color": {
            "text": "#ffffff",
            "background": "var(--wp--preset--color--hover)"
          }
